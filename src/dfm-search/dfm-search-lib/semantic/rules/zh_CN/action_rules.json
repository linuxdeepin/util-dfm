{
    "version": "1.0.0",
    "groups": [
        {
            "name": "action",
            "version": "1.0.0",
            "locale": "zh-CN",
            "rules": [
                {
                    "id": "action_create",
                    "pattern": "新建的|创建的|存下来的|保存的|新加的",
                    "description": "Action: created files (BirthTime)",
                    "enabled": true,
                    "priority": 200,
                    "metadata": {
                        "time_field": "birth"
                    }
                },
                {
                    "id": "action_modify",
                    "pattern": "修改过的|编辑过的|修改的|改过的|写过的|更新的",
                    "description": "Action: modified files (ModifyTime)",
                    "enabled": true,
                    "priority": 200,
                    "metadata": {
                        "time_field": "modify"
                    }
                },
                {
                    "id": "action_hidden_file",
                    "pattern": "隐藏文件|隐藏的|藏起来的|看不到的",
                    "description": "Action: search hidden files (include hidden flag)",
                    "enabled": true,
                    "priority": 190,
                    "metadata": {
                        "include_hidden": true
                    }
                },
                {
                    "id": "action_im_receive",
                    "pattern": "发给我的|接收的|别人传的|传给我的|别人发的|别人给的",
                    "description": "Action: IM received files — maps to all IM received-file directories",
                    "enabled": true,
                    "priority": 170,
                    "metadata": {
                        "im_category": "received"
                    }
                }
            ]
        }
    ]
}
